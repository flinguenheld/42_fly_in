# Theme colours:
#   - primary
#   - secondary
#   - accent
#   - foreground
#   - background
#   - success
#   - warning
#   - error
#   - surface
#   - panel

Screen {
	layout: vertical;
	border: round $primary;
	content-align: center middle;
}

.layout_canvas {
	align: center middle;
}

TTitle {
	color: $primary;
	content-align: center middle;
}

Canvas {
	width: auto;
	height: auto;
	border: round $primary;
	background: $background;
	# align: center middle;
	# content-align: center middle;
}

# Theme colours:
#   - primary
#   - secondary
#   - accent
#   - foreground
#   - background
#   - success
#   - warning
#   - error
#   - surface
#   - panel

TFile {
	align: center middle;
}

.tfile_layout {
	color: $primary;
	border: round $primary;
	content-align: center middle;

	width: 80;
	height: 42;
	padding: 0 2 2 2;
}

.tfile_help {
	content-align: center middle;
	color: $accent;
	width: 100%;
	margin: 1 0;
}

# #############################################################################
# ################################################################# BUTTON ####
.tfile_bt_layout {
	align: center middle;
}

.tfile_button {
	margin: 0 5;
}

# #############################################################################
# ################################################################### LIST ####
.tfile_list {
	background: $background;
	align: center middle;
	margin: 2;
}

.tfile_item {
	width: 100%;
	# height: 3;
	# color: $primary;
	content-align: center middle;
	# border: thick $primary;
}

